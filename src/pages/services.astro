---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Services — SecureProspective">
  <Nav />

  <main>
    {/* ───────────────────────── PAGE HERO ───────────────────────── */}
    <section class="page-hero">
      <div class="container hero-inner">
        <div class="eyebrow">Services</div>
        <h1 class="page-title">
          <span class="reveal-word">Two</span>
          <span class="reveal-word">paths.</span>
          <span class="reveal-word">One</span>
          <span class="reveal-word">method.</span>
        </h1>
        <p class="hero-sub">
          One engagement for businesses ready to go AI-native. One for financial
          professionals who need infrastructure support. The method is the same either way.
        </p>
      </div>
    </section>

    {/* ───────────────────── PATH A ───────────────────── */}
    <section class="path path--white">
      <div class="container">
        <div class="path-label animate-in">Path A</div>
        <h2 class="path-title animate-in">AI-Native Transformation</h2>
        <p class="path-target animate-in">
          For: established businesses running AI as a feature and ready to make it native.
        </p>

        <div class="deliverables animate-group">
          <div class="deliverable animate-item">
            <div class="deliverable-num">01</div>
            <div>
              <div class="deliverable-name">Diagnose engagement</div>
              <div class="deliverable-desc">
                Bottleneck mapping, tool audit, process documentation.
              </div>
            </div>
          </div>
          <div class="deliverable animate-item">
            <div class="deliverable-num">02</div>
            <div>
              <div class="deliverable-name">Position phase</div>
              <div class="deliverable-desc">
                Tool selection, environment preparation, integration scoping.
              </div>
            </div>
          </div>
          <div class="deliverable animate-item">
            <div class="deliverable-num">03</div>
            <div>
              <div class="deliverable-name">Shape phase</div>
              <div class="deliverable-desc">
                Output structure design, ownership transfer, documentation.
              </div>
            </div>
          </div>
          <div class="deliverable animate-item">
            <div class="deliverable-num">04</div>
            <div>
              <div class="deliverable-name">Transform phase</div>
              <div class="deliverable-desc">
                Native architecture implementation, re-diagnosis loop setup.
              </div>
            </div>
          </div>
        </div>

        <p class="scope-note animate-in">
          This is not a dashboard subscription or an AI-in-a-box product. This is diagnostic
          and architectural work. Engagements are scoped individually.
        </p>

        <a href="/contact" class="btn animate-in">Start with a conversation &rarr;</a>
      </div>
    </section>

    {/* ───────────────────── PATH B ───────────────────── */}
    <section class="path path--silver">
      <div class="container">
        <div class="path-label animate-in">Path B</div>
        <h2 class="path-title animate-in">Insurance Producer Infrastructure</h2>
        <p class="path-target animate-in">
          For: independent financial professionals, agents, and small IMOs who need advanced
          case design, annuity suitability support, and operational infrastructure.
        </p>

        <div class="deliverables animate-group">
          <div class="deliverable animate-item">
            <div class="deliverable-num">·</div>
            <div>
              <div class="deliverable-name">Case design support</div>
              <div class="deliverable-desc">Advanced case design for complex client situations.</div>
            </div>
          </div>
          <div class="deliverable animate-item">
            <div class="deliverable-num">·</div>
            <div>
              <div class="deliverable-name">Product positioning</div>
              <div class="deliverable-desc">Carrier and product placement fit to the client picture.</div>
            </div>
          </div>
          <div class="deliverable animate-item">
            <div class="deliverable-num">·</div>
            <div>
              <div class="deliverable-name">FERS / federal benefits specialty</div>
              <div class="deliverable-desc">
                FERS, CSRS, TSP, FEHB, and LEO/ATC/researcher variations.
              </div>
            </div>
          </div>
          <div class="deliverable animate-item">
            <div class="deliverable-num">·</div>
            <div>
              <div class="deliverable-name">Annuity suitability &amp; NY Reg 187 compliance</div>
              <div class="deliverable-desc">Suitability workflow and best-interest compliance.</div>
            </div>
          </div>
          <div class="deliverable animate-item">
            <div class="deliverable-num">·</div>
            <div>
              <div class="deliverable-name">Agent development</div>
              <div class="deliverable-desc">Training and infrastructure for producing agents.</div>
            </div>
          </div>
        </div>

        <p class="scope-note animate-in">
          This is the practice SecureProspective has operated for six years. The consulting
          method grew out of running this infrastructure internally.
        </p>

        <a href="/contact" class="btn animate-in">Get in touch &rarr;</a>
      </div>
    </section>

    {/* ───────────────────── HOW IT WORKS ───────────────────── */}
    <section class="how">
      <div class="container">
        <h2 class="how-title animate-in">How it works.</h2>

        <ol class="steps animate-group">
          <li class="step animate-item">
            <div class="step-num">01</div>
            <div class="step-body">
              <div class="step-name">Conversation</div>
              <div class="step-desc">
                No RFP, no form. A direct conversation about what you are trying to solve.
              </div>
            </div>
          </li>
          <li class="step animate-item">
            <div class="step-num">02</div>
            <div class="step-body">
              <div class="step-name">Diagnosis</div>
              <div class="step-desc">
                Before any engagement is scoped, the bottleneck gets identified. No
                diagnosis, no proposal.
              </div>
            </div>
          </li>
          <li class="step animate-item">
            <div class="step-num">03</div>
            <div class="step-body">
              <div class="step-name">Engagement</div>
              <div class="step-desc">
                Scoped to the diagnosis. Priced to the work. Not a retainer subscription.
              </div>
            </div>
          </li>
        </ol>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero {
    background: var(--silver-base);
    border-bottom: 2px solid var(--ink);
    padding: var(--space-7) 0;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .page-title {
    font-size: var(--text-h1);
    line-height: 1.05;
    max-width: 900px;
  }
  .hero-sub {
    font-size: var(--text-body-lg);
    max-width: 720px;
    line-height: 1.5;
  }

  /* ── Paths ── */
  .path {
    padding: var(--space-7) 0;
    border-bottom: 2px solid var(--ink);
  }
  .path--white {
    background: var(--white);
    border-top: 2px solid var(--ink);
  }
  .path--silver {
    background: var(--silver-base);
  }

  .path-label {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--blue-brand);
    margin-bottom: var(--space-3);
  }
  .path-title {
    font-size: var(--text-h2);
    margin-bottom: var(--space-3);
  }
  .path-target {
    font-size: var(--text-body-lg);
    max-width: 760px;
    margin-bottom: var(--space-6);
  }

  /* ── Deliverables ── */
  .deliverables {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .deliverable {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--space-3);
    border-top: 1px solid var(--ink);
    padding-top: var(--space-3);
    align-items: start;
  }
  .deliverable-num {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    color: var(--blue-brand);
    line-height: 1;
  }
  .deliverable-name {
    font-family: var(--font-display);
    font-size: var(--text-body);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-1);
  }
  .deliverable-desc {
    font-size: var(--text-caption);
    line-height: 1.5;
    opacity: 0.8;
  }

  .scope-note {
    font-size: var(--text-caption);
    line-height: 1.6;
    opacity: 0.7;
    max-width: 680px;
    margin-bottom: var(--space-5);
    border-left: 2px solid var(--ink);
    padding-left: var(--space-3);
  }

  /* ── How it works ── */
  .how {
    background: var(--ink);
    color: var(--ink-inverted);
    padding: var(--space-7) 0;
  }
  .how-title {
    font-size: var(--text-h2);
    color: var(--white);
    margin-bottom: var(--space-6);
  }
  .steps {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    align-items: start;
  }
  .step:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }
  .step-num {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--yellow-accent);
    line-height: 1;
  }
  .step-name {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: var(--space-2);
  }
  .step-desc {
    font-size: var(--text-body);
    color: var(--white);
    opacity: 0.85;
    max-width: 640px;
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .page-title {
      font-size: var(--text-h2);
    }
    .deliverables {
      grid-template-columns: 1fr;
    }
    .step {
      grid-template-columns: 48px 1fr;
      gap: var(--space-3);
    }
  }
</style>
