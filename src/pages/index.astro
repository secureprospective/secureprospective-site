---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="SecureProspective — Make AI native. Drop the prefix.">
  <Nav />

  <main>
    {/* ───────────────────────── HERO ───────────────────────── */}
    <section class="hero">
      <div class="container hero-inner">
        <h1 class="hero-title">
          <span class="reveal-word">Make</span> <span class="reveal-word">AI</span>
          <span class="reveal-word">native.</span><br />
          <span class="reveal-word">Drop</span> <span class="reveal-word">the</span>
          <span class="reveal-word">prefix.</span>
        </h1>
        <p class="hero-sub">
          We make businesses AI-native — diagnose the bottleneck, position the tool,
          shape the output for ownership.
        </p>
        <a href="/the-method" class="btn">See the method &rarr;</a>
      </div>
    </section>

    {/* ───────────────────── METHOD PREVIEW ───────────────────── */}
    <section class="method-preview">
      <div class="container">
        <div class="eyebrow eyebrow--white">The Method</div>

        <div class="transit-map animate-group">
          <div class="transit-node animate-item">
            <div class="node-marker">01</div>
            <div class="node-name">Diagnose</div>
            <div class="node-desc">Find what's actually broken.</div>
          </div>
          <div class="transit-node animate-item">
            <div class="node-marker">02</div>
            <div class="node-name">Position</div>
            <div class="node-desc">Set the tool up for success.</div>
          </div>
          <div class="transit-node animate-item">
            <div class="node-marker">03</div>
            <div class="node-name">Shape</div>
            <div class="node-desc">Structure output for ownership.</div>
          </div>
          <div class="transit-node animate-item">
            <div class="node-marker">04</div>
            <div class="node-name">Transform</div>
            <div class="node-desc">AI-native. Prefix dropped.</div>
          </div>
        </div>
      </div>
    </section>

    {/* ───────────────────── PROOF TEASERS ───────────────────── */}
    <section class="proof-teasers">
      <div class="container">
        <div class="eyebrow">The Work</div>

        <div class="teasers animate-group">
          <article class="teaser animate-item">
            <div class="teaser-meta">DATA_RECORD // 001</div>
            <h3 class="teaser-title">TFM — Client #1</h3>
            <p class="teaser-desc">
              Tech Freedom Ministries — faith-backed digital freedom nonprofit. Built the
              digital infrastructure, brand system, and live site. The method's first
              external application.
            </p>
          </article>
          <article class="teaser animate-item">
            <div class="teaser-meta">DATA_RECORD // 002</div>
            <h3 class="teaser-title">The IMO</h3>
            <p class="teaser-desc">
              We ran an IMO. We knew what was broken. We applied the method to our own
              business first. ~$110M in annuity production. ~$18M/yr current volume.
            </p>
          </article>
        </div>
      </div>
    </section>

    {/* ───────────────────── OPERATOR TEASER ───────────────────── */}
    <section class="operator-teaser">
      <div class="container operator-inner animate-in">
        <p class="operator-quote">
          Three careers. One spine. Built it before consulting it.
        </p>
        <p class="operator-sub">
          Fifteen years electrical. Twenty-six years technology. Insurance, annuity, and
          IMO leadership. The four-movement method wasn't invented in a deck.
        </p>
        <a href="/the-operator" class="btn">Meet the operator &rarr;</a>
      </div>
    </section>

    {/* ───────────────────── LOOP-CLOSER ───────────────────── */}
    <section class="loop-closer">
      <div class="container loop-inner animate-in">
        <p class="loop-line">What's native today gets re-diagnosed tomorrow.</p>
        <p class="loop-sub">
          The loop doesn't end — your business just stops being the bottleneck.
        </p>
        <a href="/contact" class="btn">Start with a conversation &rarr;</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--silver-base);
    border-bottom: 2px solid var(--ink);
    padding: var(--space-8) 0;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .hero-title {
    font-size: var(--text-display);
    line-height: 1;
    letter-spacing: -0.02em;
    max-width: 900px;
  }
  .hero-sub {
    font-size: var(--text-body-lg);
    max-width: 680px;
    line-height: 1.5;
    color: var(--ink);
  }

  /* ── Method preview (transit map) ── */
  .method-preview {
    background: var(--blue-brand);
    color: var(--ink-inverted);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    padding: var(--space-7) 0;
  }
  .eyebrow--white {
    color: var(--white);
  }

  .transit-map {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  /* horizontal connector — desktop */
  .transit-map::before {
    content: '';
    position: absolute;
    top: 15px;
    left: 16px;
    right: 16px;
    height: 2px;
    background: var(--white);
    z-index: 0;
  }
  .transit-node {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .node-marker {
    width: 32px;
    height: 32px;
    background: var(--blue-brand);
    border: 2px solid var(--white);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-3);
  }
  .node-name {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }
  .node-desc {
    font-size: var(--text-body);
    color: var(--white);
    opacity: 0.85;
  }

  /* ── Proof teasers ── */
  .proof-teasers {
    background: var(--silver-base);
    border-bottom: 2px solid var(--ink);
    padding: var(--space-7) 0;
  }
  .teasers {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  .teaser {
    background: var(--white);
    padding: var(--space-5);
    border: 1px solid var(--ink);
    transition: border-color 120ms ease-out;
  }
  .teaser:hover {
    border-color: var(--blue-brand);
  }
  .teaser-meta {
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--ink);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
  }
  .teaser-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }
  .teaser-desc {
    font-size: var(--text-caption);
    line-height: 1.6;
  }

  /* ── Operator teaser ── */
  .operator-teaser {
    background: var(--ink);
    color: var(--ink-inverted);
    padding: var(--space-7) 0;
  }
  .operator-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
  }
  .operator-quote {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    text-transform: uppercase;
    color: var(--white);
    line-height: 1.1;
    max-width: 1000px;
  }
  .operator-sub {
    font-size: var(--text-body-lg);
    color: var(--white);
    opacity: 0.85;
    max-width: 820px;
  }

  /* ── Loop-closer ── */
  .loop-closer {
    background: var(--blue-brand);
    padding: var(--space-6) 0;
  }
  .loop-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
  }
  .loop-line {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    text-transform: uppercase;
    color: var(--white);
  }
  .loop-sub {
    font-size: var(--text-body);
    color: var(--white);
    opacity: 0.85;
    margin-bottom: var(--space-3);
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .hero-title {
      font-size: 48px;
    }
    .operator-quote {
      font-size: var(--text-h2);
    }
    .transit-map {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    /* vertical connector on mobile */
    .transit-map::before {
      top: 16px;
      left: 15px;
      right: auto;
      width: 2px;
      bottom: 16px;
      height: auto;
    }
    .teasers {
      grid-template-columns: 1fr;
    }
  }
</style>
